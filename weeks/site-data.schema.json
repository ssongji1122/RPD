{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpd.local/weeks/site-data.schema.json",
  "title": "RPD Canonical Curriculum",
  "type": "array",
  "items": {
    "$ref": "#/$defs/week"
  },
  "$defs": {
    "task": {
      "type": "object",
      "required": ["id", "label", "detail"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "detail": { "type": "string" }
      }
    },
    "resource": {
      "type": "object",
      "required": ["title", "url"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 }
      }
    },
    "shortcut": {
      "type": "object",
      "required": ["keys", "action"],
      "additionalProperties": false,
      "properties": {
        "keys": { "type": "string", "minLength": 1 },
        "action": { "type": "string", "minLength": 1 }
      }
    },
    "explore": {
      "type": "object",
      "required": ["title", "hint"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "hint": { "type": "string", "minLength": 1 }
      }
    },
    "download": {
      "type": "object",
      "required": ["label", "url"],
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 }
      }
    },
    "clip": {
      "type": "object",
      "required": ["label", "src"],
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "src": { "type": "string", "minLength": 1 }
      }
    },
    "step": {
      "type": "object",
      "required": ["title", "copy", "goal", "done", "tasks"],
      "additionalProperties": true,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "copy": { "type": "string", "minLength": 1 },
        "goal": {
          "type": "array",
          "items": { "type": "string" }
        },
        "done": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tasks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/task" }
        },
        "showme": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 1
            }
          ]
        },
        "image": { "type": "string" },
        "images": {
          "type": "array",
          "items": { "type": "string" }
        },
        "link": { "type": "string" },
        "video": { "type": "string" },
        "downloads": {
          "type": "array",
          "items": { "$ref": "#/$defs/download" }
        },
        "clips": {
          "type": "array",
          "items": { "$ref": "#/$defs/clip" }
        },
        "sectionTitle": { "type": "string" }
      }
    },
    "assignment": {
      "type": "object",
      "required": ["title", "description", "checklist"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "checklist": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      }
    },
    "week": {
      "type": "object",
      "required": [
        "week",
        "status",
        "title",
        "subtitle",
        "duration",
        "topics",
        "steps",
        "shortcuts",
        "explore",
        "assignment",
        "mistakes",
        "videos",
        "docs"
      ],
      "additionalProperties": true,
      "properties": {
        "week": { "type": "integer", "minimum": 1 },
        "status": {
          "type": "string",
          "enum": ["done", "active", "upcoming"]
        },
        "title": { "type": "string", "minLength": 1 },
        "subtitle": { "type": "string" },
        "summary": { "type": "string" },
        "duration": { "type": "string", "minLength": 1 },
        "topics": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/step" }
        },
        "shortcuts": {
          "type": "array",
          "items": { "$ref": "#/$defs/shortcut" }
        },
        "explore": {
          "type": "array",
          "items": { "$ref": "#/$defs/explore" }
        },
        "assignment": { "$ref": "#/$defs/assignment" },
        "mistakes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "videos": {
          "type": "array",
          "items": { "$ref": "#/$defs/resource" }
        },
        "docs": {
          "type": "array",
          "items": { "$ref": "#/$defs/resource" }
        }
      }
    }
  }
}
