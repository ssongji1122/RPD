{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "course-site",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["tools/admin-server.py"],
      "port": 8766,
      "env": {
        "ADMIN_KEY": "5059"
      }
    },
    {
      "name": "course-site-static",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "course-site"],
      "port": 8772,
      "autoPort": true
    },
    {
      "name": "course-site-preview",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "course-site"],
      "port": 8773,
      "autoPort": true
    }
  ]
}
